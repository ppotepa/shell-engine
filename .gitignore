/target/

# Rust/Cargo
**/*.rs.bk

# Editor/OS
.DS_Store
Thumbs.db

# Local notes: ignore all markdown except the root README.md
*.md
**/*.md
!/README.md

# Build artifacts and reports
*-report.txt
concat-report.txt

# Runtime logs (keep logs/ directory structure)
*.log
!logs/

# Raw authored asset sources stay local
!mods/*/assets/raw/.gitignore
