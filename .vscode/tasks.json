{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Shell Quest (app)",
      "type": "shell",
      "command": "cargo run -p app",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Run Shell Quest (release)",
      "type": "shell",
      "command": "cargo run -p app --release",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Check workspace",
      "type": "shell",
      "command": "cargo check --workspace",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": [
        "$rustc"
      ]
    },
    {
      "label": "Test workspace",
      "type": "shell",
      "command": "cargo test -q",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": [
        "$rustc"
      ]
    }
  ]
}
