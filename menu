#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
MODS_DIR="${ROOT_DIR}/mods"

if [[ ! -d "${MODS_DIR}" ]]; then
  echo "[menu] missing mods directory: ${MODS_DIR}" >&2
  exit 1
fi

# ── colours ──────────────────────────────────────────────────────────
BOLD=$'\e[1m'
DIM=$'\e[2m'
CYAN=$'\e[36m'
YELLOW=$'\e[33m'
GREEN=$'\e[32m'
WHITE=$'\e[97m'
RESET=$'\e[0m'
REVERSE=$'\e[7m'
BLUE=$'\e[34m'
MAGENTA=$'\e[35m'

# ── data collection ─────────────────────────────────────────────────
declare -a ITEMS=()       # display labels
declare -a ITEM_TYPES=()  # "mod" | "scene"
declare -a ITEM_PATHS=()  # mod dir for mod rows, scene path for scene rows
declare -a ITEM_MOD=()    # mod dir that owns this item
declare -a ITEM_SEARCH=() # plain-text searchable label (lowercase)
declare -a MOD_EXPANDED=()
declare -a MOD_INDICES=()
declare -a MOD_NAMES_LIST=()

# Search state
SEARCH_QUERY=""
declare -a FILTERED_IDX=()  # indices into ITEMS[] that match current query

build_tree() {
  ITEMS=()
  ITEM_TYPES=()
  ITEM_PATHS=()
  ITEM_MOD=()
  ITEM_SEARCH=()

  local mod_idx=0
  local dir manifest display_name

  while IFS= read -r dir; do
    manifest="${dir}/mod.yaml"
    [[ -f "${manifest}" ]] || continue

    display_name="$(awk '
      /^[[:space:]]*name:[[:space:]]*/ {
        sub(/^[[:space:]]*name:[[:space:]]*/, "", $0)
        gsub(/^"|"$/, "", $0)
        print $0
        exit
      }
    ' "${manifest}")"
    [[ -z "${display_name}" ]] && display_name="$(basename "${dir}")"

    # store mod index mapping
    MOD_INDICES+=("${#ITEMS[@]}")
    MOD_NAMES_LIST+=("${display_name}")

    # default expand state
    if [[ -z "${MOD_EXPANDED[mod_idx]+x}" ]]; then
      MOD_EXPANDED[mod_idx]=0
    fi

    local arrow="▶"
    if (( MOD_EXPANDED[mod_idx] )); then arrow="▼"; fi

    ITEMS+=("${arrow} ${display_name}")
    ITEM_TYPES+=("mod")
    ITEM_PATHS+=("${dir}")
    ITEM_MOD+=("${dir}")
    ITEM_SEARCH+=("${display_name,,}")

    if (( MOD_EXPANDED[mod_idx] )); then
      local scenes_dir="${dir}/scenes"
      if [[ -d "${scenes_dir}" ]]; then
        local scene_dir scene_yml scene_id scene_title
        while IFS= read -r scene_dir; do
          scene_yml=""
          if [[ -f "${scene_dir}/scene.yml" ]]; then
            scene_yml="${scene_dir}/scene.yml"
          elif [[ -f "${scene_dir}.yml" ]]; then
            scene_yml="${scene_dir}.yml"
          else
            continue
          fi

          scene_id="$(awk '
            /^[[:space:]]*id:[[:space:]]*/ {
              sub(/^[[:space:]]*id:[[:space:]]*/, "", $0)
              gsub(/^"|"$/, "", $0)
              print $0
              exit
            }
          ' "${scene_yml}")"

          scene_title="$(awk '
            /^[[:space:]]*title:[[:space:]]*/ {
              sub(/^[[:space:]]*title:[[:space:]]*/, "", $0)
              gsub(/^"|"$/, "", $0)
              print $0
              exit
            }
          ' "${scene_yml}")"

          local label="${scene_id:-$(basename "${scene_dir}")}"
          local search_text="${label,,}"
          [[ -n "${scene_title}" ]] && search_text="${search_text} ${scene_title,,}"
          [[ -n "${scene_title}" ]] && label="${label} ${DIM}— ${scene_title}${RESET}"

          ITEMS+=("    ${label}")
          ITEM_TYPES+=("scene")
          ITEM_PATHS+=("${scene_yml}")
          ITEM_MOD+=("${dir}")
          ITEM_SEARCH+=("${search_text}")
        done < <(find "${scenes_dir}" -mindepth 1 -maxdepth 1 -type d | sort)
      fi
    fi

    (( mod_idx++ )) || true
  done < <(find "${MODS_DIR}" -mindepth 1 -maxdepth 1 -type d | sort)
}

# ── apply search filter ─────────────────────────────────────────────
apply_filter() {
  FILTERED_IDX=()
  if [[ -z "${SEARCH_QUERY}" ]]; then
    local i
    for (( i = 0; i < ${#ITEMS[@]}; i++ )); do
      FILTERED_IDX+=("$i")
    done
  else
    local query="${SEARCH_QUERY,,}"
    local i
    for (( i = 0; i < ${#ITEMS[@]}; i++ )); do
      # always include mods (to keep tree structure)
      if [[ "${ITEM_TYPES[$i]}" == "mod" ]]; then
        # include mod if any of its scenes match
        local mod_dir="${ITEM_PATHS[$i]}"
        local has_match=0
        local j
        for (( j = 0; j < ${#ITEMS[@]}; j++ )); do
          if [[ "${ITEM_TYPES[$j]}" == "scene" && "${ITEM_MOD[$j]}" == "${mod_dir}" ]]; then
            if [[ "${ITEM_SEARCH[$j]}" == *"${query}"* ]]; then
              has_match=1
              break
            fi
          fi
        done
        if (( has_match )); then
          FILTERED_IDX+=("$i")
        fi
      else
        if [[ "${ITEM_SEARCH[$i]}" == *"${query}"* ]]; then
          FILTERED_IDX+=("$i")
        fi
      fi
    done
  fi
}

# ── find mod index for a tree row ───────────────────────────────────
get_mod_index_for_row() {
  local row=$1
  local mod_dir="${ITEM_MOD[$row]}"
  local mi=0
  local j
  for j in "${!ITEM_PATHS[@]}"; do
    if [[ "${ITEM_TYPES[$j]}" == "mod" ]]; then
      if [[ "${ITEM_PATHS[$j]}" == "${mod_dir}" ]]; then
        echo "${mi}"
        return
      fi
      (( mi++ )) || true
    fi
  done
  echo 0
}

# ── drawing ─────────────────────────────────────────────────────────
draw_menu() {
  local cur=$1  # cursor into FILTERED_IDX
  local total=${#FILTERED_IDX[@]}

  printf '\e[H\e[J'

  echo "${BOLD}${CYAN}  Shell Quest — Mod & Scene Launcher${RESET}"
  if [[ -n "${SEARCH_QUERY}" ]]; then
    echo "${DIM}  ↑↓ navigate  Enter launch  Esc clear search  Backspace delete${RESET}"
  else
    echo "${DIM}  ↑↓ navigate  →/Enter expand/launch  ←/Esc collapse  / search  q quit${RESET}"
  fi
  echo ""

  if (( total == 0 )); then
    echo "  ${DIM}no matches${RESET}"
  else
    local i real_idx
    for (( i = 0; i < total; i++ )); do
      real_idx="${FILTERED_IDX[$i]}"
      local line="${ITEMS[$real_idx]}"

      if (( i == cur )); then
        if [[ "${ITEM_TYPES[$real_idx]}" == "mod" ]]; then
          printf "  ${REVERSE}${BOLD}${YELLOW}${line}${RESET}\n"
        else
          printf "  ${REVERSE}${GREEN}${line}${RESET}\n"
        fi
      else
        if [[ "${ITEM_TYPES[$real_idx]}" == "mod" ]]; then
          printf "  ${BOLD}${WHITE}${line}${RESET}\n"
        else
          printf "  ${BLUE}${line}${RESET}\n"
        fi
      fi
    done
  fi

  echo ""
  if [[ -n "${SEARCH_QUERY}" ]]; then
    local scene_count=0
    local i
    for (( i = 0; i < total; i++ )); do
      if [[ "${ITEM_TYPES[${FILTERED_IDX[$i]}]}" == "scene" ]]; then
        (( scene_count++ )) || true
      fi
    done
    echo "  ${MAGENTA}/${SEARCH_QUERY}${RESET}  ${DIM}(${scene_count} scene$(if (( scene_count != 1 )); then echo s; fi))${RESET}"
  elif (( total > 0 )); then
    local real_idx="${FILTERED_IDX[$cur]}"
    if [[ "${ITEM_TYPES[$real_idx]}" == "mod" ]]; then
      echo "  ${DIM}mod: $(basename "${ITEM_PATHS[$real_idx]}")${RESET}"
    else
      echo "  ${DIM}scene: ${ITEM_PATHS[$real_idx]}${RESET}"
    fi
  fi
}

# ── read single keypress ────────────────────────────────────────────
read_key() {
  local key
  IFS= read -rsn1 key
  if [[ "${key}" == $'\e' ]]; then
    local seq
    IFS= read -rsn2 -t 0.05 seq || true
    key="${key}${seq}"
  fi
  echo "${key}"
}

# ── launch a scene ──────────────────────────────────────────────────
launch_scene() {
  local real_idx=$1
  local mod_dir="${ITEM_MOD[$real_idx]}"
  local scene_yml="${ITEM_PATHS[$real_idx]}"
  local rel_scene="${scene_yml#"${mod_dir}"/}"

  printf '\e[?25h\e[?1049l'
  trap - EXIT
  echo "[menu] launching scene: ${rel_scene} from $(basename "${mod_dir}")"
  "${ROOT_DIR}/launcher.sh" --mod-source "${mod_dir}" --start-scene "/${rel_scene}" --skip-splash --in-place --no-hold
  printf '\e[?25l\e[?1049h'
  trap 'printf "\e[?25h\e[?1049l"' EXIT
}

launch_mod() {
  local real_idx=$1
  printf '\e[?25h\e[?1049l'
  trap - EXIT
  echo "[menu] launching mod: ${ITEM_PATHS[$real_idx]}"
  "${ROOT_DIR}/launcher.sh" --mod-source "${ITEM_PATHS[$real_idx]}" --in-place --no-hold
  printf '\e[?25l\e[?1049h'
  trap 'printf "\e[?25h\e[?1049l"' EXIT
}

# ── main loop ───────────────────────────────────────────────────────
main() {
  local cursor=0

  printf '\e[?25l\e[?1049h'
  trap 'printf "\e[?25h\e[?1049l"' EXIT

  build_tree

  if (( ${#ITEMS[@]} == 0 )); then
    printf '\e[?25h\e[?1049l'
    echo "[menu] no mods found under ${MODS_DIR}" >&2
    exit 1
  fi

  apply_filter

  while true; do
    # auto-select: if search active and exactly one scene matches, snap cursor to it
    if [[ -n "${SEARCH_QUERY}" ]]; then
      local scene_matches=0 last_scene_fi=-1 fi_idx
      for (( fi_idx = 0; fi_idx < ${#FILTERED_IDX[@]}; fi_idx++ )); do
        if [[ "${ITEM_TYPES[${FILTERED_IDX[$fi_idx]}]}" == "scene" ]]; then
          (( scene_matches++ )) || true
          last_scene_fi=$fi_idx
        fi
      done
      if (( scene_matches == 1 && last_scene_fi >= 0 )); then
        cursor=$last_scene_fi
      fi
    fi

    draw_menu "${cursor}"

    local key
    key="$(read_key)"

    # ── search mode: typing characters ──────────────────────────────
    if [[ -n "${SEARCH_QUERY}" ]]; then
      case "${key}" in
        $'\e[A') # UP
          if (( cursor > 0 )); then cursor=$((cursor - 1)); fi
          ;;
        $'\e[B') # DOWN
          if (( cursor < ${#FILTERED_IDX[@]} - 1 )); then cursor=$((cursor + 1)); fi
          ;;
        ''|$'\e[C') # Enter or RIGHT — launch
          if (( ${#FILTERED_IDX[@]} > 0 )); then
            local real_idx="${FILTERED_IDX[$cursor]}"
            if [[ "${ITEM_TYPES[$real_idx]}" == "scene" ]]; then
              launch_scene "$real_idx"
              SEARCH_QUERY=""
              apply_filter
              cursor=0
            fi
          fi
          ;;
        $'\e') # Esc — clear search
          SEARCH_QUERY=""
          apply_filter
          cursor=0
          ;;
        $'\x7f'|$'\b') # Backspace
          if [[ ${#SEARCH_QUERY} -gt 0 ]]; then
            SEARCH_QUERY="${SEARCH_QUERY%?}"
            apply_filter
            cursor=0
          fi
          if [[ -z "${SEARCH_QUERY}" ]]; then
            apply_filter
            cursor=0
          fi
          ;;
        [[:print:]]) # any printable char → append to query
          SEARCH_QUERY+="${key}"
          # expand all mods so scenes are searchable
          local mi
          for (( mi = 0; mi < ${#MOD_EXPANDED[@]}; mi++ )); do
            MOD_EXPANDED[$mi]=1
          done
          MOD_INDICES=()
          MOD_NAMES_LIST=()
          build_tree
          apply_filter
          cursor=0
          ;;
      esac
    else
      # ── normal tree mode ──────────────────────────────────────────
      case "${key}" in
        $'\e[A') # UP
          if (( cursor > 0 )); then cursor=$((cursor - 1)); fi
          ;;
        $'\e[B') # DOWN
          if (( cursor < ${#FILTERED_IDX[@]} - 1 )); then cursor=$((cursor + 1)); fi
          ;;
        $'\e[C'|'') # RIGHT or Enter — expand/launch
          if (( ${#FILTERED_IDX[@]} == 0 )); then continue; fi
          local real_idx="${FILTERED_IDX[$cursor]}"
          if [[ "${ITEM_TYPES[$real_idx]}" == "mod" ]]; then
            local mi
            mi="$(get_mod_index_for_row "$real_idx")"
            if (( MOD_EXPANDED[mi] )); then
              launch_mod "$real_idx"
            else
              MOD_EXPANDED[$mi]=1
              local old_path="${ITEM_PATHS[$real_idx]}"
              MOD_INDICES=()
              MOD_NAMES_LIST=()
              build_tree
              apply_filter
              local i
              for i in "${!FILTERED_IDX[@]}"; do
                if [[ "${ITEM_TYPES[${FILTERED_IDX[$i]}]}" == "mod" && "${ITEM_PATHS[${FILTERED_IDX[$i]}]}" == "${old_path}" ]]; then
                  cursor=$i
                  break
                fi
              done
            fi
          else
            launch_scene "$real_idx"
          fi
          ;;
        $'\e[D'|$'\e') # LEFT or Esc — collapse
          if (( ${#FILTERED_IDX[@]} == 0 )); then continue; fi
          local real_idx="${FILTERED_IDX[$cursor]}"
          local mi
          mi="$(get_mod_index_for_row "$real_idx")"
          if (( MOD_EXPANDED[mi] )); then
            MOD_EXPANDED[$mi]=0
            local mod_dir="${ITEM_MOD[$real_idx]}"
            MOD_INDICES=()
            MOD_NAMES_LIST=()
            build_tree
            apply_filter
            local i
            for i in "${!FILTERED_IDX[@]}"; do
              if [[ "${ITEM_TYPES[${FILTERED_IDX[$i]}]}" == "mod" && "${ITEM_PATHS[${FILTERED_IDX[$i]}]}" == "${mod_dir}" ]]; then
                cursor=$i
                break
              fi
            done
          fi
          ;;
        '/') # start search
          SEARCH_QUERY=""
          # expand all mods
          local mi
          for (( mi = 0; mi < ${#MOD_EXPANDED[@]}; mi++ )); do
            MOD_EXPANDED[$mi]=1
          done
          MOD_INDICES=()
          MOD_NAMES_LIST=()
          build_tree
          apply_filter
          cursor=0
          ;;
        [[:print:]]) # direct typing also starts search
          SEARCH_QUERY="${key}"
          local mi
          for (( mi = 0; mi < ${#MOD_EXPANDED[@]}; mi++ )); do
            MOD_EXPANDED[$mi]=1
          done
          MOD_INDICES=()
          MOD_NAMES_LIST=()
          build_tree
          apply_filter
          cursor=0
          ;;
        q|Q)
          exit 0
          ;;
      esac
    fi

    # clamp cursor
    local total=${#FILTERED_IDX[@]}
    if (( total == 0 )); then
      cursor=0
    else
      if (( cursor >= total )); then cursor=$(( total - 1 )); fi
      if (( cursor < 0 )); then cursor=0; fi
    fi
  done
}

main "$@"
